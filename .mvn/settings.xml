<?xml version="1.0" encoding="UTF-8"?>
<!--
  IKE Tooling — Project-Level Maven Settings
  ═══════════════════════════════════════════

  Maven 4 loads this file from .mvn/settings.xml automatically.
  These settings supplement (not replace) ~/.m2/settings.xml.
-->
<settings xmlns="http://maven.apache.org/SETTINGS/2.0.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/2.0.0
          https://maven.apache.org/xsd/settings-2.0.0.xsd">
    <!-- Allow 'mvn ike:help' shorthand instead of full GAV. -->
    <pluginGroups>
        <pluginGroup>network.ike</pluginGroup>
    </pluginGroups>

    <mirrors>
        <!-- Block the mavengem:https://rubygems.org repository declared
             transitively by asciidoctorj's jruby-stdlib dependency.
             Maven cannot access mavengem: URLs without the mavengem-wagon
             extension, producing a [WARNING] on every build. This mirror
             intercepts requests to that repository and returns nothing. -->
        <mirror>
            <id>block-mavengems</id>
            <mirrorOf>mavengems*</mirrorOf>
            <url>https://0.0.0.0/</url>
            <blocked>true</blocked>
        </mirror>
    </mirrors>
</settings>
